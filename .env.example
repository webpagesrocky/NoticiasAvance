# ===========================================================================
# Copia este archivo como ".env" y pon tus llaves reales adentro.
# El archivo .env NUNCA se sube a GitHub (lo bloquea .gitignore).
# ===========================================================================

# Llave de NewsAPI (https://newsapi.org) - fuente principal de noticias
NEWS_API_KEY=

# Llave de GNews (https://gnews.io) - fuente de respaldo
GNEWS_API_KEY=

# Llave de Anthropic (https://console.anthropic.com) - clasifica y resume
ANTHROPIC_API_KEY=

# Proveedor de noticias activo: "newsapi" o "gnews"
NEWS_PROVIDER=newsapi
